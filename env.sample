# True in development, False in production
DEBUG=True

FLASK_APP=run.py
FLASK_ENV=development

# If not provided, a random one is generated in DEBUG only
# REQUIRED in production (16+ characters):
# SECRET_KEY=change-me-to-a-long-random-string

# Local PostgreSQL (required — no Docker)
DB_ENGINE=postgresql+psycopg2
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=akram_shareholders
DB_USERNAME=akram_user
DB_PASS=akram_pass

# Optional: single connection string (overrides DB_*). URL-encode special characters in passwords.
# DATABASE_URL=postgresql+psycopg2://akram_user:akram_pass@127.0.0.1:5432/akram_shareholders

# Optional admin credentials for scripts/setup_database.py
# (omit these if you run: sudo -u postgres python scripts/setup_database.py)
# POSTGRES_ADMIN_USER=postgres
# POSTGRES_ADMIN_PASSWORD=

# SQLite is only for offline/unit checks (scripts/verify_app.py sets this itself)
# DB_ENGINE=sqlite
# SQLITE_PATH=apps/db.sqlite3

# Used for CDN (in production)
# No slash at the end
ASSETS_ROOT=/static

# Email (required for OTP login and shareholder report emails)
# Incomplete SMTP + LOGIN_OTP_ENABLED=true blocks interactive login.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=you@gmail.com
# Gmail: use an App Password (no spaces), not your normal password
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=you@gmail.com
MAIL_FROM=you@gmail.com

# Login OTP (email verification after password)
# Set to false for local password-only login when SMTP is not ready.
LOGIN_OTP_ENABLED=true
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Demo seed (admin/finance/shareholder sample users).
# true = always seed when missing; false = never; omit = seed only when DEBUG=true
# SEED_DEMO_DATA=false

# Schema: prefer `flask --app run.py db upgrade`.
# Only set true once in DEBUG to drop/recreate when migrations cannot apply.
# ALLOW_SCHEMA_RESET=false

# byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# tests and coverage
.pytest_cache/
*.pytest_cache
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# database & logs
*.db
*.sqlite3
*.log

# virtual environments
.env
.env.*
!.env.example
env/
venv/
.venv/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# sphinx docs
_build
_static
_templates

# javascript / frontend tooling
node_modules/
package-lock.json
.vscode/symbols.json

apps/static/node_modules/
apps/static/yarn.lock
apps/static/.temp

# user-uploaded brand assets (keep folder + default logo)
apps/static/uploads/brand/*
!apps/static/uploads/brand/.gitkeep
!apps/static/uploads/brand/logo-default.png
apps/static/uploads/signatures/*
!apps/static/uploads/signatures/.gitkeep
apps/static/uploads/media/*
!apps/static/uploads/media/.gitkeep

# Flask-Migrate / Alembic revisions (commit these — required for clean deploys)
# Ignore only local bytecode under migrations
migrations/**/__pycache__/
